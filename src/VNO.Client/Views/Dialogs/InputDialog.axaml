<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="VNO.Client.Views.Dialogs.InputDialog"
        Title="VNO"
        SizeToContent="WidthAndHeight"
        CanResize="False"
        WindowStartupLocation="CenterOwner">

    <!-- Stand in for the legacy InputBox prompt, plain like the stock dialog -->
    <StackPanel Margin="16" Spacing="12" MinWidth="280">
        <TextBlock x:Name="PromptText" TextWrapping="Wrap" />
        <TextBox x:Name="ValueBox" />
        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
            <Button x:Name="OkButton" Content="OK" Width="80" HorizontalContentAlignment="Center" />
            <Button x:Name="CancelButton" Content="Cancel" Width="80" HorizontalContentAlignment="Center" />
        </StackPanel>
    </StackPanel>
</Window>
