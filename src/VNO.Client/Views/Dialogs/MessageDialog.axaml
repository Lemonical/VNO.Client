<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="VNO.Client.Views.Dialogs.MessageDialog"
        Icon="/Assets/VNO_FINAL_1_0_Icon.ico"
        Title="VNO"
        SizeToContent="WidthAndHeight"
        CanResize="False"
        WindowStartupLocation="CenterOwner">

    <!-- Stand in for the legacy ShowMessage popup, plain like the stock dialog -->
    <StackPanel Margin="16" Spacing="12" MinWidth="260" MaxWidth="420">
        <TextBlock x:Name="MessageText" TextWrapping="Wrap" />
        <Button x:Name="OkButton" Content="OK" Width="80"
                HorizontalAlignment="Center" HorizontalContentAlignment="Center" />
    </StackPanel>
</Window>
