<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:VNO.Client.ViewModels"
        x:Class="VNO.Client.Views.MainWindow"
        Icon="/Assets/VNO_FINAL_1_0_Icon.ico"
        x:DataType="vm:MainWindowViewModel"
        Title="VNO Remix Beta: 3rd Strike"
        SizeToContent="WidthAndHeight"
        CanResize="True"
        CanMaximize="False"
        WindowStartupLocation="CenterScreen"
        Background="White">

    <!-- The shell hosts whichever screen the navigator has made current.
         The original Form15 resized itself per screen, so the window sizes to the
         active screen view. The view locator turns the screen view model into its view -->
    <Viewbox Stretch="Uniform">
        <ContentControl Content="{Binding Navigator.CurrentScreen}" />
    </Viewbox>
</Window>
